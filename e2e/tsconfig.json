{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework", "@wdio/tauri-service"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@domain": ["../crates/app/ui/src/domain.ts"]
    }
  },
  "include": ["wdio.conf.ts", "specs/**/*.ts", "src/**/*.ts", "types/**/*.d.ts"]
}
