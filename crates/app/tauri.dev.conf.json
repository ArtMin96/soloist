{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "mcp-bridge",
          "description": "Dev-only: lets the MCP bridge plugin drive the main webview for AI-agent debugging.",
          "windows": ["main"],
          "permissions": ["mcp-bridge:default"]
        }
      ]
    }
  }
}
