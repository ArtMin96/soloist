{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "dev.soloist.app.e2e",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "wdio",
          "description": "E2e-only: lets the WebdriverIO harness attach to and drive the main webview.",
          "windows": [
            "main"
          ],
          "permissions": [
            "wdio:default",
            "wdio-webdriver:default"
          ]
        }
      ]
    }
  }
}
