{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soloist",
  "version": "0.1.0",
  "identifier": "dev.soloist.app",
  "mainBinaryName": "soloist",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "ui/dist",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Soloist",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Process supervisor and AI-agent coordination workspace.",
    "longDescription": "Soloist runs your dev stack and CLI coding agents from one dashboard, keeps them alive, and gives them a shared, project-scoped workspace over MCP.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
