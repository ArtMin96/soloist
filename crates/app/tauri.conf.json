{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soloist",
  "version": "0.9.5",
  "identifier": "dev.soloist.app",
  "mainBinaryName": "soloist",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "ui/dist",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && cargo build --release --package soloist-mcp --package soloist-cli"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Soloist",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "maximized": true,
        "decorations": false
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": {
        "default-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob:",
        "font-src": "'self' data:",
        "connect-src": "ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'"
      },
      "freezePrototype": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "Soloist contributors",
    "shortDescription": "Process supervisor and AI-agent coordination workspace.",
    "longDescription": "Soloist runs your dev stack and CLI coding agents from one dashboard, keeps them alive, and gives them a shared, project-scoped workspace over MCP.",
    "linux": {
      "deb": {
        "section": "devel",
        "recommends": ["shared-mime-info", "desktop-file-utils"],
        "desktopTemplate": "bundle/soloist.desktop",
        "files": {
          "/usr/share/mime/packages/soloist.xml": "bundle/soloist-mimetype.xml",
          "/usr/bin/soloist-mcp": "../../target/release/soloist-mcp",
          "/usr/bin/soloist-cli": "../../target/release/soloist-cli"
        },
        "postInstallScript": "bundle/deb-postinst.sh",
        "postRemoveScript": "bundle/deb-postrm.sh"
      },
      "appimage": {
        "bundleMediaFramework": false,
        "files": {
          "/usr/bin/soloist-mcp": "../../target/release/soloist-mcp",
          "/usr/bin/soloist-cli": "../../target/release/soloist-cli"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDQjU2OTMzREY5MTEzRjEKUldUeEU1SGZNMm0xL0JxNnZ5WlY4TlMrcDNoSTcxbUpwVzdCd1hTU3l5cnBjQmc5OXo2STZjeFoK",
      "endpoints": [
        "https://github.com/ArtMin96/soloist/releases/latest/download/latest.json"
      ]
    }
  }
}
